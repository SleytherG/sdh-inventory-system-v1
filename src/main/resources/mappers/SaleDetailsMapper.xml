    <insert id="createSaleDetails" useGeneratedKeys="true" keyProperty="id" keyColumn="id">
        INSERT INTO SALE_DETAILS (sale_id, product_id, quantity, unit_price, subtotal)
        VALUES (#{saleDetails.saleId}, #{saleDetails.productId}, #{saleDetails.quantity}, #{saleDetails.unitPrice}, #{saleDetails.subTotal})
    </insert>

