<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="sdh.store.inventory.manager.sale_details.mappers.SaleDetailsMapper">

    <resultMap id="SalesDTOResultMap" type="sdh.store.inventory.manager.sale_details.dto.SaleDetailsDTO">
        <id property="id" column="SALES_ID" />
        <result property="quantity" column="QUANTITY" />
        <result property="unitPrice" column="UNIT_PRICE" />
        <result property="subTotal" column="SUB_TOTAL" />

        <association property="product" javaType="sdh.store.inventory.manager.sale_details.dto.ProductSaleDetailsDTO">
            <id property="id" column="ID_CATEGORY" />
            <result property="name" column="PRODUCT_NAME" />
            <result property="description" column="PRODUCT_DESCRIPTION" />
            <result property="price" column="PRODUCT_PRICE" />
            <result property="stockQuantity" column="PRODUCT_STOCK_QUANTITY" />
        </association>
    </resultMap>


